# ============================================
# IntelliKnow KMS Configuration
# ============================================
# Copy this file to .env and update with your values

# ============================================
# DASHSCOPE API CONFIGURATION
# ============================================
DASHSCOPE_API_KEY=your-dashscope-api-key-here

# Vision Model (for table extraction from PDFs)
VISION_MODEL=qwen-vl-plus

# Embedding Model
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSION=1024

# Intent Classification Model (lightweight, fast)
# Options: qwen-turbo (fastest), qwen-plus (balanced), qwen-max-latest (strongest)
INTENT_MODEL=qwen-turbo

# Response Generation Model (high quality)
# Options: qwen-turbo (fastest), qwen-plus (balanced), qwen-max-latest (strongest)
LLM_MODEL=qwen-turbo

# LLM Generation Parameters
LLM_TEMPERATURE=0.7
MAX_TOKENS=1500

# Document Retrieval Configuration
# Number of documents to retrieve (1-5, lower = faster, higher = more comprehensive)
RETRIEVAL_TOP_K=2

# Intent Classification Confidence Threshold (0.0-1.0)
INTENT_CONFIDENCE_THRESHOLD=0.7

# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_URL=sqlite:///./intelliknow.db

# ============================================
# ORCHESTRATION MODE
# ============================================
# LangChain Mode: Fast, single-turn optimized (USE_LANGCHAIN=true)
# Original Mode: Multi-turn, clarification support (USE_LANGCHAIN=false)
USE_LANGCHAIN=true

# ============================================
# APPLICATION CONFIGURATION
# ============================================
APP_NAME=IntelliKnow KMS
APP_VERSION=1.0.0
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production

# Server Configuration
API_HOST=0.0.0.0
API_PORT=8000

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=pdf,docx,xlsx,excel

# Vector Database
VECTOR_DB_DIR=./faiss_index

# ============================================
# BOT INTEGRATIONS
# ============================================

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Microsoft Teams Bot
TEAMS_APP_ID=your-teams-app-id-here
TEAMS_APP_PASSWORD=your-teams-app-password-here

# Feishu/Lark Bot
FEISHU_APP_ID=your-feishu-app-id-here
FEISHU_APP_SECRET=your-feishu-app-secret-here
FEISHU_VERIFICATION_TOKEN=your-verification-token-here
FEISHU_ENCRYPT_KEY=your-encrypt-key-here
FEISHU_WEBHOOK_URL=https://your-domain.com/api/bot/feishu/webhook

# DingTalk Bot
DINGTALK_WEBHOOK_URL=your-dingtalk-webhook-url-here
DINGTALK_APP_KEY=your-dingtalk-app-key-here
DINGTALK_APP_SECRET=your-dingtalk-app-secret-here
